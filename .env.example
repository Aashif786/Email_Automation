# Caldim Digital Postmaster Environment Configuration

# URL pointing directly to the n8n instance's Webhook trigger/endpoint
# (e.g., http://localhost:5678/webhook/caldim-digital-postmaster)
REACT_APP_N8N_WEBHOOK_URL="http://localhost:5678/webhook/caldim-digital-postmaster"

# Key authorization header for requests passing through endpoints
REACT_APP_API_KEY="caldim_secure_postmaster_token_xyz"

# Local directory path where n8n saves email attachments
# The backend script serving /api/attachments requires this mapping
N8N_FILE_STORAGE_VOLUME="/home/node/.n8n-files"

# Port configuration for the React Dashboard development server
PORT=3000
